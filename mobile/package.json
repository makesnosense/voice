{
  "name": "voice",
  "version": "0.9.2",
  "private": true,
  "scripts": {
    "android": "adb reverse tcp:3003 tcp:3003 && react-native run-android --appId org.voicepopuli.voice.dev",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "android:clean": "cd android && ./gradlew clean",
    "android:release": "cd android && ./gradlew assembleRelease",
    "android:release:install": "adb install $(ls android/app/build/outputs/apk/release/*.apk)",
    "android:release:run": "npm run android:release && npm run android:release:install"
  },
  "dependencies": {
    "@react-native-clipboard/clipboard": "^1.16.3",
