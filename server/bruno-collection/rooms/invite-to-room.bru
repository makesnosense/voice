meta {
  name: invite-to-room
  type: http
  seq: 3
}

post {
  url: https://localhost:3003/api/rooms/{{voiceRoomId}}/invite
  body: json
  auth: bearer
}

auth:bearer {
  token: {{voiceAccessToken}}
}

body:json {
  
  {
    "targetUserId": "{{voiceUserId}}"
  } 
}

settings {
  encodeUrl: true
  timeout: 0
}
