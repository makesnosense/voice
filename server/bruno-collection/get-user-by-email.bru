meta {
  name: get-user-by-email
  type: http
  seq: 5
}

get {
  url: https://localhost:3003/api/users?email=noldya@gmail.com
  body: json
  auth: bearer
}

params:query {
  email: noldya@gmail.com
}

auth:bearer {
  token: {{voiceAccessToken}}
}

script:post-response {
  const response = res.getBody();
  if (response && response.id) {
    bru.setVar("voiceUserId", response.id);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
