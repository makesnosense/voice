meta {
  name: calls
  type: http
  seq: 3
}

post {
  url: https://localhost:3003/api/calls/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{voiceAccessToken}}
}

body:json {
  
  {
    "targetUserId": "{{voiceUserId}}"
  }
}

script:post-response {
  const response = res.getBody();
  if (response && response.callId) {
    bru.setVar("voiceCallId", response.callId);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
