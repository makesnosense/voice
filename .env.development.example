NODE_ENVIRONMENT=development
RATE_LIMITING_ENABLED=false

# server
SERVER_HOST=localhost
SERVER_PORT=3003
CLIENT_PORT=5177
CORS_ORIGINS=https://localhost:5177

# ssl — run sudo ./scripts/issue-server-dev-certs.sh to generate, it will print these paths
SSL_KEY_PATH=
SSL_CERT_PATH=

# database — must match POSTGRES_* values below
DATABASE_URL=postgresql://voice:password@localhost:5432/voice_dev

# postgres docker container (used by spin-up-dev-postgres.sh)
POSTGRES_DB=voice_dev
POSTGRES_USER=voice
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432

# auth — any random string works for dev
JWT_SECRET=

# dev login bypass — set to anything, use these credentials to log in without resend
REVIEW_EMAIL=
REVIEW_OTP_CODE=

# resend — optional, not needed if using review bypass above
RESEND_API_KEY=

# coturn (tier 2: set host to localhost, tier 4: set host to your public VPS — see README)
COTURN_SECRET=
VITE_TURN_SERVER_HOST=localhost
VITE_TURN_SERVER_PORT=3478

# tier 3: firebase cloud messaging — optional, push notifications disabled if absent
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=
